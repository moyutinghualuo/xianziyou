{"config":{"lang":["zh"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u6b22\u8fce\u6765\u5230\u5c0f\u8bf4 Wiki","text":"<p>\u8fd9\u662f\u4e00\u4e2a\u5173\u4e8e\u300a\u4ed9\u5b50\u6e38\u300b\u7684\u4e16\u754c\u89c2 Wiki \u77e5\u8bc6\u5e93\u3002\u5728\u8fd9\u91cc\u4f60\u53ef\u4ee5\uff1a</p> <ul> <li>\ud83d\udcd6 \u6d4f\u89c8 \u4e16\u754c\u89c2\u8bbe\u5b9a \u2014 \u5730\u56fe\u3001</li> <li>\ud83d\udc64 \u4e86\u89e3 \u89d2\u8272\u6863\u6848 \u2014 \u4e3b\u89d2\u3001\u914d\u89d2\u3001\u4eba\u7269\u5173\u7cfb</li> <li>\ud83d\udcdd \u8ffd\u8e2a \u60c5\u8282\u53d1\u5c55 \u2014 \u5404\u5377\u7ae0\u8282\u6982\u8981</li> <li>\ud83d\udcda \u67e5\u9605 \u672f\u8bed\u8bcd\u6c47 \u2014 \u4e13\u6709\u540d\u8bcd\u89e3\u91ca\u3001\u89e3\u91ca\u5b57\u8bcd</li> </ul>"},{"location":"#_1","title":"\u5feb\u901f\u5bfc\u822a","text":"<ul> <li>\u4e16\u754c\u89c2\u6982\u89c8</li> <li>\u9b54\u6cd5\u4f53\u7cfb</li> <li>\u5730\u7406\u5fd7</li> <li>\u89d2\u8272\u5217\u8868</li> <li>\u672f\u8bed\u8868</li> </ul> <p>\u4f7f\u7528\u5de6\u4fa7\u5bfc\u822a\u680f\u6d4f\u89c8\u6240\u6709\u9875\u9762\uff0c\u6309 <code>/</code> \u952e\u5feb\u901f\u641c\u7d22\u3002</p>"},{"location":"characters/characters/","title":"\u89d2\u8272\u5217\u8868","text":""},{"location":"characters/characters/#_2","title":"\ud83d\udc68\u200d\ud83c\udf93 \u4e3b\u8981\u89d2\u8272","text":""},{"location":"characters/characters/#_3","title":"\u5f85\u5b9a\uff08\u4e3b\u89d2\uff09","text":"<p>\u57fa\u672c\u4fe1\u606f - \u6027\u522b\uff1a\u5f85\u5b9a - \u5e74\u9f84\uff1a\u5f85\u5b9a - \u8eab\u4efd\uff1a\u5f85\u5b9a - \u4fee\u4e3a\uff1a\u70bc\u6c14\u671f</p> <p>\u80cc\u666f\u6545\u4e8b - \u8eab\u4e16\uff1a\u5f85\u5b9a - \u673a\u9047\uff1a\u5f85\u5b9a - \u76ee\u6807\uff1a\u5f85\u5b9a</p> <p>\u6027\u683c\u7279\u5f81 - \u4f18\u70b9\uff1a\u5f85\u5b9a - \u7f3a\u70b9\uff1a\u5f85\u5b9a - \u68a6\u60f3\uff1a\u5f85\u5b9a</p>"},{"location":"characters/characters/#_4","title":"\u5f85\u5b9a\uff08\u5e08\u7236\uff09","text":"<p>\u57fa\u672c\u4fe1\u606f - \u6027\u522b\uff1a\u5f85\u5b9a - \u4fee\u4e3a\uff1a\u5316\u795e\u671f - \u8eab\u4efd\uff1a\u5b97\u95e8\u957f\u8001</p> <p>\u6545\u4e8b\u5173\u7cfb - \u4e0e\u4e3b\u89d2\u7684\u5173\u7cfb - \u9690\u85cf\u7684\u79d8\u5bc6 - \u91cd\u8981\u7684\u8f6c\u6298\u70b9</p>"},{"location":"characters/characters/#_5","title":"\ud83d\udc65 \u914d\u89d2","text":"<p>\u7b2c\u4e00\u5377\u914d\u89d2</p> <ul> <li>\u5f85\u5b9a\u89d2\u82721</li> <li>\u5f85\u5b9a\u89d2\u82722</li> <li>\u5f85\u5b9a\u89d2\u82723</li> </ul> <p>\u7b2c\u4e8c\u5377\u914d\u89d2</p> <ul> <li>\u5f85\u5b9a\u89d2\u82724</li> <li>\u5f85\u5b9a\u89d2\u82725</li> </ul>"},{"location":"characters/characters/#_6","title":"\ud83d\udde3\ufe0f \u89d2\u8272\u5173\u7cfb\u56fe","text":"<pre><code>\u4e3b\u89d2\n  \u251c\u2500 \u5e08\u7236\uff08\u6307\u5bfc\u8005\uff09\n  \u251c\u2500 \u540c\u95e8\uff08\u4f19\u4f34\uff09\n  \u251c\u2500 \u654c\u4eba\uff08\u5bf9\u624b\uff09\n  \u2514\u2500 \u5176\u4ed6\uff08\u5f85\u5b9a\uff09\n</code></pre>"},{"location":"characters/characters/#_7","title":"\ud83d\udccb \u89d2\u8272\u8bbe\u5b9a\u6a21\u677f","text":"<p>\u5bf9\u4e8e\u65b0\u589e\u89d2\u8272\uff0c\u8bf7\u6309\u4ee5\u4e0b\u683c\u5f0f\u586b\u5199\uff1a</p>"},{"location":"characters/characters/#_8","title":"\u89d2\u8272\u540d","text":"\u5c5e\u6027 \u503c \u6027\u522b \u5e74\u9f84 \u4fee\u4e3a \u8eab\u4efd \u7279\u70b9 \u80cc\u666f"},{"location":"characters/relationships/","title":"\u4eba\u7269\u5173\u7cfb","text":""},{"location":"characters/relationships/#_2","title":"\u6838\u5fc3\u5173\u7cfb","text":"<ul> <li>\u827e\u7433 \u2194 \u51ef\u6069\uff1a\u4fdd\u62a4\u8005\u4e0e\u88ab\u4fdd\u62a4\u8005\u3002\u51ef\u6069\u6700\u521d\u53ea\u5f53\u662f\u4efb\u52a1\uff0c\u9010\u6e10\u4ea7\u751f\u8d85\u8d8a\u804c\u8d23\u7684\u611f\u60c5\u3002</li> <li>\u827e\u7433 \u2194 \u8389\u5a1c\uff1a\u4ece\u654c\u5bf9\u5230\u751f\u6b7b\u4e4b\u4ea4\u3002\u8389\u5a1c\u672c\u662f\u6765\u523a\u6740\u827e\u7433\u7684\uff0c\u5374\u88ab\u5979\u7684\u771f\u8bda\u6253\u52a8\u3002</li> <li>\u51ef\u6069 \u2194 \u8389\u5a1c\uff1a\u4e92\u4e0d\u4fe1\u4efb\u2192\u5e76\u80a9\u4f5c\u6218\u3002\u4e24\u4eba\u7684\u4ef7\u503c\u89c2\u51b2\u7a81\u4e0e\u78e8\u5408\u662f\u672c\u4f5c\u91cd\u8981\u526f\u7ebf\u3002</li> <li>\u8d5b\u5fb7 \u2194 \u827e\u7433\uff1a\u5bfc\u5e08\u4e0e\u5b66\u751f\u3002\u8d5b\u5fb7\u5f15\u5bfc\u827e\u7433\u638c\u63e1\u65f6\u7a7a\u9b54\u6cd5\u3002</li> <li>\u8d5b\u5fb7 \u2194 \u51ef\u6069\uff1a\u4e92\u76f8\u5c0a\u91cd\u4f46\u7406\u5ff5\u4e0d\u540c\u3002\u7cbe\u7075\u7684\"\u957f\u8fdc\u773c\u5149\"\u4e0e\u4eba\u7c7b\u7684\"\u5f53\u4e0b\u884c\u52a8\"\u4e4b\u4e89\u3002</li> </ul>"},{"location":"characters/relationships/#_3","title":"\u9635\u8425\u5173\u7cfb","text":"<pre><code>[\u4e3b\u89d2\u56e2] \u2014\u2014\u5bf9\u6297\u2014\u2014\u2192 [\u6697\u5f71\u4e4b\u4e3b]\n    \u2193                    \u2193\n[\u9b54\u6cd5\u5b66\u9662]          [\u6697\u5f71\u8bae\u4f1a]\n    \u2193                    \u2193\n[\u5e1d\u56fd\u7687\u5ba4] \u2190\u2014\u2014\u535a\u5f08\u2014\u2014\u2192 [\u5317\u5883\u516c\u7235]\n</code></pre> <p>\u4eba\u5404\u6709\u5fd7\uff0c\u9053\u4e0d\u540c\u4e0d\u76f8\u4e3a\u8c0b\uff0c\u4f46\u547d\u8fd0\u7684\u4e1d\u7ebf\u603b\u4f1a\u5c06\u91cd\u8981\u7684\u4eba\u7f16\u7ec7\u5728\u4e00\u8d77\u3002</p>"},{"location":"glossary/terms/","title":"\u672f\u8bed\u8868","text":""},{"location":"glossary/terms/#_2","title":"\u4fee\u70bc\u76f8\u5173\u672f\u8bed","text":""},{"location":"glossary/terms/#_3","title":"\u7075\u6c14","text":"<p>\u5929\u5730\u95f4\u7684\u80fd\u91cf\uff0c\u662f\u4fee\u4ed9\u8005\u4fee\u70bc\u7684\u57fa\u7840\u3002\u4e0d\u540c\u5730\u65b9\u7075\u6c14\u6d53\u5ea6\u4e0d\u540c\u3002</p>"},{"location":"glossary/terms/#_4","title":"\u6cd5\u529b","text":"<p>\u4fee\u4ed9\u8005\u901a\u8fc7\u4fee\u70bc\u5438\u6536\u7075\u6c14\u8f6c