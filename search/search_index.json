01\u7684\u6218\u4e89\u53d1\u751f\u4e86\u4ec0\u4e48\uff1f</li> <li>\u706d\u4e16\u9057\u8ff9\u4e2d\u9690\u85cf\u7740\u4ec0\u4e48\uff1f</li> <li>\u4e3a\u4ec0\u4e48\u9b54\u9053\u6700\u8fd1\u6d3b\u8dc3\uff1f</li> <li>\u795e\u79d8\u4eba\u7269\u7684\u76ee\u7684\u662f\u4ec0\u4e48\uff1f</li> </ol>"},{"location":"plot/volume-1/chapter-01/","title":"\u7b2c\u4e00\u7ae0\uff1a\u9884\u8a00\u4e4b\u5b50","text":""},{"location":"plot/volume-1/chapter-01/#_2","title":"\u6982\u8981","text":"<p>\u5317\u5883\u8fb9\u5883\u5c0f\u6751 \u971c\u53f6\u6751 \u906d\u9047\u9b54\u517d\u88ad\u51fb\uff0c\u5341\u4e03\u5c81\u7684\u5c11\u5973 \u827e\u7433 \u5728\u751f\u6b7b\u5173\u5934\u89c9\u9192\u4e86\u65f6\u7a7a\u9b54\u6cd5\u2014\u2014\u5979\u770b\u89c1\u4e86\u9b54\u517d\u653b\u51fb\u524d\u4e94\u79d2\u7684\u672a\u6765\u3002</p> <p>\u5e1d\u56fd\u9a91\u58eb \u51ef\u6069\u00b7\u94c1\u58c1 \u7387\u961f\u5de1\u903b\u81f3\u6b64\uff0c\u76ee\u7779\u4e86\u8fd9\u4e0d\u53ef\u601d\u8bae\u7684\u4e00\u5e55\u3002\u4ed6\u7acb\u5373\u610f\u8bc6\u5230\uff0c\u8fd9\u4e2a\u5c11\u5973\u5c31\u662f\u9884\u8a00\u4e2d\"\u80fd\u591f\u7aa5\u89c1\u65f6\u95f4\u4e4b\u4eba\"\u3002</p>"},{"location":"plot/volume-1/chapter-01/#_3","title":"\u5173\u952e\u60c5\u8282","text":"<ol> <li>\u971c\u53f6\u6751\u7684\u5e73\u9759\u65e5\u5e38 \u2192 \u9b54\u517d\u7a81\u88ad</li> <li>\u827e\u7433\u89c9\u9192 \u2192 \u9884\u77e5\u95ea\u907f\u81f4\u547d\u4e00\u51fb</li> <li>\u51ef\u6069\u51fa\u73b0 \u2192 \u51fb\u9000\u9b54\u517d</li> <li>\u51ef\u6069\u51b3\u5b9a\u5e26\u827e\u7433\u524d\u5f80\u9b54\u6cd5\u5b66\u9662</li> <li>\u6697\u5904\uff0c\u4e00\u53cc\u773c\u775b\u6ce8\u89c6\u7740\u8fd9\u4e00\u5207\u2026\u2026</li> </ol>"},{"location":"plot/volume-1/chapter-01/#_4","title":"\u767b\u573a\u89d2\u8272","text":"<ul> <li>\u827e\u7433\u00b7\u661f\u8bed \u2014 \u9996\u6b21\u767b\u573a</li> <li>\u51ef\u6069\u00b7\u94c1\u58c1 \u2014 \u9996\u6b21\u767b\u573a</li> </ul>"},{"location":"plot/volume-1/chapter-01/#_5","title":"\u4e16\u754c\u89c2\u4fe1\u606f","text":"<ul> <li>\u9b54\u517d\u6765\u81ea \u8ff7\u96fe\u6d77 \u65b9\u5411</li> <li>\u65f6\u7a7a\u9b54\u6cd5\u9996\u6b21\u51fa\u73b0\u4e8e \u4e1c\u9646\u9b54\u6cd5\u5b66\u9662 \u7684\u8bb0\u8f7d\u4e4b\u5916</li> </ul>"},{"location":"world-building/geography/","title":"\u5730\u7406\u5fd7","text":""},{"location":"world-building/geography/#_2","title":"\ud83d\uddfa\ufe0f \u4e94\u5dde\u7248\u56fe","text":""},{"location":"world-building/geography/#_3","title":"\u4e2d\u5dde","text":"<p>\u6700\u7e41\u534e\u7684\u4fee\u4ed9\u5927\u9646</p> <ul> <li>\u9762\u79ef\uff1a\u6700\u5927</li> <li>\u4eba\u53e3\uff1a\u6700\u591a</li> <li>\u5b97\u95e8\uff1a\u6700\u5bc6\u96c6</li> <li>\u7279\u70b9\uff1a\u4e2d\u539f\u8179\u5730\uff0c\u4fee\u4ed9\u8d44\u6e90\u4e30\u5bcc</li> </ul> <p>\u4e3b\u8981\u57ce\u5e02\uff1a - \u5b97\u95e8\u8054\u76df\u57ce - \u4ea4\u6613\u4e2d\u5fc3\u57ce - \u4f20\u627f\u5854</p>"},{"location":"world-building/geography/#_4","title":"\u5317\u8352","text":"<p>\u5996\u517d\u4e0e\u51b0\u971c\u7684\u56fd\u5ea6</p> <ul> <li>\u6c14\u5019\uff1a\u4e25\u5bd2</li> <li>\u751f\u7269\uff1a\u5996\u517d\u4f17\u591a</li> <li>\u8d44\u6e90\uff1a\u7a00\u6709\u77ff\u7269\u3001\u5bd2\u51b0\u7cbe\u9ad3</li> <li>\u7279\u70b9\uff1a\u5371\u9669\u4e0e\u673a\u9047\u5e76\u5b58</li> </ul> <p>\u4e3b\u8981\u5730\u70b9\uff1a - \u5996\u517d\u68ee\u6797 - \u51b0\u5ddd\u4e4b\u5fc3 - \u5317\u6781\u79d8\u5883</p>"},{"location":"world-building/geography/#_5","title":"\u897f\u6f20","text":"<p>\u53e4\u8ff9\u4e0e\u79d8\u5bc6\u7684\u6c99\u6f20</p> <ul> <li>\u6c14\u5019\uff1a\u708e\u70ed\u5e72\u71e5</li> <li>\u7279\u70b9\uff1a\u4e0a\u53e4\u6587\u660e\u9057\u8ff9</li> <li>\u8d44\u6e90\uff1a\u53e4\u5b9d\u3001\u79d8\u7c4d</li> <li>\u5371\u9669\uff1a\u8bc5\u5492\u3001\u5080\u5121</li> </ul> <p>\u4e3b\u8981\u9057\u8ff9\uff1a - \u6c99\u6f20\u53e4\u57ce - \u91d1\u5b57\u5854\u9057\u8ff9 - \u79d8\u85cf\u6d1e\u7a9f</p>"},{"location":"world-building/geography/#_6","title":"\u5357\u7586","text":"<p>\u86ee\u8352\u4e0e\u795e\u79d8\u4e4b\u5883</p> <ul> <li>\u6c14\u5019\uff1a\u708e\u70ed\u591a\u96e8</li> <li>\u751f\u7269\uff1a\u86ee\u65cf\u3001\u5f02\u79cd</li> <li>\u7279\u70b9\uff1a\u539f\u59cb\u529b\u91cf\u5f3a\u5927</li> <li>\u8d44\u6e90\uff1a\u5b9d\u836f\u3001\u9b42\u77f3</li> </ul> <p>\u4e3b\u8981\u52bf\u529b\uff1a - \u86ee\u65cf\u90e8\u843d - \u517d\u4eba\u738b\u5ead - \u90aa\u6559\u7ec4\u7ec7</p>"},{"location":"world-building/geography/#_7","title":"\u4e1c\u6d32","text":"<p>\u6d77\u6d0b\u4e0e\u5c9b\u5c7f\u7684\u4f20\u8bf4</p> <ul> <li>\u7279\u70b9\uff1a\u591a\u5c9b\u5c7f\u3001\u591a\u6d77\u4e0a\u52bf\u529b</li> <li>\u8d44\u6e90\uff1a\u73cd\u73e0\u3001\u6d77\u517d\u6750\u6599</li> <li>\u6587\u660e\uff1a\u6d77\u4e0a\u4fee\u4ed9\u5b97\u95e8</li> </ul> <p>\u4e3b\u8981\u533a\u57df\uff1a - \u4e1c\u6d0b\u8bf8\u5c9b - \u6df1\u6d77\u79d8\u5883 - \u822a\u6d77\u8d38\u6613\u8def\u7ebf</p>"},{"location":"world-building/geography/#_8","title":"\ud83c\udfef \u8457\u540d\u5730\u70b9","text":""},{"location":"world-building/geography/#_9","title":"\u7981\u5730","text":"<p>\u4e09\u5927\u7981\u5730</p> <ol> <li>\u706d\u4e16\u9057\u8ff9 \u2014 \u4e0a\u53e4\u6218\u573a\uff0c\u80fd\u91cf\u6df7\u4e71</li> <li>\u5815\u6e0a\u4e4b\u4e0b \u2014 \u9b54\u6c14\u6c47\u805a\uff0c\u751f\u4eba\u52ff\u8fdb</li> <li>\u65f6\u7a7a\u88c2\u7f1d \u2014 \u89c4\u5219\u6df7\u4e71\uff0c\u5750\u6807\u4e0d\u5b9a</li> </ol>"},{"location":"world-building/geography/#_10","title":"\u5723\u5730","text":"<p>\u4e94\u5927\u5723\u5730</p> <ol> <li>\u4ed9\u6b66\u5cf0 \u2014 \u6700\u9ad8\u7684\u5c71\u5cf0\uff0c\u7075\u6c14\u6700\u6d53</li> <li>\u609f\u9053\u6e56 \u2014 \u9002\u5408\u987f\u609f\u7684\u5723\u5730</li> <li>\u751f\u6b7b\u8c37 \u2014 \u5386\u7ec3\u8005\u7684\u5fc5\u7ecf\u4e4b\u5730</li> <li>\u957f\u751f\u6797 \u2014 \u795e\u79d8\u7684\u53e4\u8001\u68ee\u6797</li> <li>\u5929\u95e8\u5173 \u2014 \u901a\u5f80\u4ed9\u754c\u7684\u5165\u53e3</li> </ol>"},{"location":"world-building/magic-system/","title":"\u9b54\u6cd5\u4f53\u7cfb","text":"<p>\u672c\u4e16\u754c\u7684\u529b\u91cf\u4f53\u7cfb\u4ee5\"\u4fee\u4ed9\"\u4e3a\u6838\u5fc3\uff0c\u901a\u8fc7\u4fee\u70bc\u83b7\u5f97\u8d85\u51e1\u529b\u91cf\u3002</p>"},{"location":"world-building/magic-system/#_2","title":"\u4fee\u4e3a\u5883\u754c","text":"<p>\u4ece\u4f4e\u5230\u9ad8\u5171\u5206\u4e3a\u5341\u4e2a\u5927\u5883\u754c\uff1a</p>"},{"location":"world-building/magic-system/#_3","title":"\u7b2c\u4e00\u9636\uff1a\u51e1\u4eba\u4fee\u884c\u671f","text":"<p>\u70bc\u6c14\u671f <code>1-9 \u5c42</code> - \u521d\u5165\u4fee\u4ed9 - \u5b66\u4e60\u57fa\u7840\u529f\u6cd5 - \u4f53\u8d28\u9010\u6e10\u6539\u53d8</p>"},{"location":"world-building/magic-system/#_4","title":"\u7b2c\u4e8c\u9636\uff1a\u865a\u7a7a\u638c\u63a7\u671f","text":"<p>\u7b51\u57fa\u671f <code>1-9 \u5c42</code> - \u5728\u4f53\u5185\u6784\u5efa\u6cd5\u529b\u5faa\u73af - \u80fd\u591f\u5fa1\u7269\u98de\u884c\u77ed\u8ddd\u79bb</p> <p>\u7ed3\u4e39\u671f <code>1-9 \u5c42</code> - \u51dd\u805a\u91d1\u4e39 - \u589e\u52a0\u6cd5\u529b\u5bb9\u91cf</p>"},{"location":"world-building/magic-system/#_5","title":"\u7b2c\u4e09\u9636\uff1a\u5929\u5730\u5171\u9e23\u671f","text":"<p>\u5143\u5a74\u671f <code>1-9 \u5c42</code> - \u5143\u5a74\u51fa\u7a8d - \u80fd\u591f\u957f\u8ddd\u79bb\u98de\u884c</p> <p>\u5316\u795e\u671f <code>1-9 \u5c42</code> - \u4e0e\u5929\u5730\u6cd5\u5219\u76f8\u878d - \u9886\u609f\u89c4\u5219\u4e4b\u529b</p>"},{"location":"world-building/magic-system/#_6","title":"\u7b2c\u56db\u9636\uff1a\u8d85\u8d8a\u51e1\u4fd7\u671f","text":"<p>\u6e21\u52ab\u671f <code>1-9 \u5c42</code> - \u7ecf\u5386\u5929\u52ab\u8003\u9a8c - \u6253\u7834\u5929\u5730\u675f\u7f1a</p> <p>\u4ed9\u4eba\u5883 <code>\u521d\u3001\u4e2d\u3001\u540e\u3001\u5706\u6ee1</code> - \u6210\u4ed9\u4e4b\u8def - \u957f\u751f\u4e0d\u8001</p>"},{"location":"world-building/magic-system/#_7","title":"\u529f\u6cd5\u5206\u7c7b","text":""},{"location":"world-building/magic-system/#_8","title":"\ud83d\udfe6 \u6b63\u9053\u529f\u6cd5","text":"<ul> <li>\u953b\u4f53\u3001\u4fee\u5fc3\u3001\u609f\u6cd5</li> <li>\u6d41\u6d3e\uff1a\u9053\u95e8\u3001\u4f5b\u95e8</li> </ul>"},{"location":"world-building/magic-system/#_9","title":"\ud83d\udfe5 \u9b54\u9053\u529f\u6cd5","text":"<ul> <li>\u63a0\u593a\u3001\u878d\u5408\u3001\u4fb5\u8680</li> <li>\u6d41\u6d3e\uff1a\u9b54\u95e8\u3001\u9b3c\u9053</li> </ul>"},{"location":"world-building/magic-system/#_10","title":"\ud83d\udfe8 \u4e2d\u7acb\u529f\u6cd5","text":"<ul> <li>\u6280\u5de7\u3001\u9635\u6cd5\u3001\u70bc\u5668</li> <li>\u6d41\u6d3e\uff1a\u5de5\u5320\u3001\u9635\u6cd5\u5e08</li> </ul>"},{"location":"world-building/magic-system/#_11","title":"\u529b\u91cf\u6765\u6e90","text":"\u6765\u6e90 \u7279\u70b9 \u4ee3\u4ef7 \u7075\u6c14\u5438\u6536 \u7a33\u5b9a\u3001\u5b89\u5168 \u4fee\u884c\u7f13\u6162 \u9b54\u6c14\u878d\u5408 \u5feb\u901f\u3001\u5f3a\u5927 \u5fc3\u5883\u4e0d\u7a33 \u8840\u8109\u6fc0\u6d3b \u5929\u8d4b\u5f3a\u5927 \u96be\u4ee5\u63a7\u5236 \u5668\u7269\u501f\u529b \u5916\u63f4\u5f3a\u5927 \u4f9d\u8d56\u6027\u5f3a"},{"location":"world-building/overview/","title":"\u4e16\u754c\u89c2\u6982\u89c8","text":"<p>\u6b22\u8fce\u6765\u5230\u4ed9\u4fa0\u4e16\u754c\u7684\u5165\u95e8\u6307\u5357\u3002\u8fd9\u91cc\u6c47\u805a\u4e86\u5173\u4e8e\u8fd9\u4e2a\u5145\u6ee1\u4ed9\u6c14\u7684\u4e16\u754c\u7684\u6240\u6709\u57fa\u672c\u4fe1\u606f\u3002</p>"},{"location":"world-building/overview/#_2","title":"\ud83c\udf0d \u4e16\u754c\u57fa\u672c\u4fe1\u606f","text":"\u9879\u76ee \u63cf\u8ff0 \u4e16\u754c\u540d\u79f0 \u5f85\u5b9a \u8bbe\u5b9a\u65f6\u4ee3 \u4fee\u4ed9\u7eaa\u5143 \u4e3b\u8981\u79cd\u65cf \u4eba\u65cf\u3001\u5996\u65cf\u3001\u795e\u65cf \u653f\u6cbb\u4f53\u5236 \u5b97\u95e8\u5236"},{"location":"world-building/overview/#_3","title":"\ud83d\udcdc \u5386\u53f2\u65f6\u4ee3","text":""},{"location":"world-building/overview/#_4","title":"\u4e0a\u53e4\u65f6\u4ee3","text":"<ul> <li>\u4ed9\u9b54\u6218\u4e89</li> <li>\u5929\u5730\u521d\u5206</li> <li>\u5404\u65cf\u72ec\u7acb</li> </ul>"},{"location":"world-building/overview/#_5","title":"\u4e2d\u53e4\u65f6\u4ee3","text":"<ul> <li>\u5b97\u95e8\u6797\u7acb</li> <li>\u9b54\u9053\u8870\u843d</li> <li>\u4eba\u65cf\u5174\u76db</li> </ul>"},{"location":"world-building/overview/#_6","title":"\u5f53\u4ee3","text":"<ul> <li>\u4fee\u4ed9\u8def\u5f00\u653e</li> <li>\u5404\u6d3e\u4e89\u950b</li> <li>\u6545\u4e8b\u5f00\u59cb</li> </ul>"},{"location":"world-building/overview/#_7","title":"\ud83c\udfd4\ufe0f \u5730\u7406\u7248\u56fe","text":"<ul> <li>\u4e2d\u5dde \u2014 \u4fee\u4ed9\u8005\u6700\u591a\u7684\u5927\u9646</li> <li>\u5317\u8352 \u2014 \u5996\u517d\u805a\u96c6\u4e4b\u5730</li> <li>\u897f\u6f20 \u2014 \u79d8\u5883\u4e0e\u53e4\u8ff9</li> <li>\u5357\u7586 \u2014 \u86ee\u8352\u4e0e\u795e\u79d8</li> <li>\u4e1c\u6d32 \u2014 \u6d77\u6d0b\u4e0e\u4f20\u8bf4</li> </ul>"},{"location":"world-building/overview/#_8","title":"\u2728 \u6838\u5fc3\u8bbe\u5b9a","text":"<p>\u4fee\u4e3a\u5883\u754c</p> <p>\u4ece\u70bc\u6c14\u5230\u98de\u5347\uff0c\u5171\u5206\u4e3a\u591a\u4e2a\u9636\u6bb5\u3002\u8be6\u89c1 \u4fee\u4e3a\u4f53\u7cfb\u3002n</p> <p>\u5b97\u95e8\u5236\u5ea6</p> <p>\u4e16\u754c\u7531\u4f17\u591a\u5b97\u95e8\u7edf\u6cbb\uff0c\u5404\u6709\u7279\u8272\u548c\u4f20\u627f\u3002</p> <p>\u7981\u5fcc\u4e4b\u5730</p> <p>\u67d0\u4e9b\u5730\u65b9\u88ab\u5217\u4e3a\u7981\u533a\uff0c\u8fdb\u5165\u8005\u591a\u6709\u53bb\u65e0\u56de\u3002</p>"},{"location":"world-building/overview/#_9","title":"\ud83d\udcda \u76f8\u5173\u94fe\u63a5","text":"<ul> <li>\u9b54\u6cd5\u4f53\u7cfb</li> <li>\u5730\u7406\u5fd7</li> <li>\u5b97\u95e8\u5927\u5168</li> </ul>"},{"location":"world-building/sects/","title":"\u5b97\u95e8\u5927\u5168","text":""},{"location":"world-building/sects/#_2","title":"\ud83c\udfd4\ufe0f \u6b63\u9053\u5b97\u95e8","text":""},{"location":"world-building/sects/#_3","title":"\u4ed9\u6b66\u5b97","text":"<p>\u6700\u53e4\u8001\u7684\u6b63\u9053\u5b97\u95e8</p> <ul> <li>\u638c\u95e8\uff1a\u5f85\u5b9a</li> <li>\u5f1f\u5b50\uff1a\u6570\u5343\u4eba</li> <li>\u4f20\u627f\uff1a\u5251\u4fee\u4e3a\u4e3b</li> <li>\u7279\u8272\u529f\u6cd5\uff1a\u300a\u4ed9\u6b66\u5251\u7ecf\u300b</li> <li>\u4f4d\u7f6e\uff1a\u4e2d\u5dde\u00b7\u4ed9\u6b66\u5cf0</li> </ul>"},{"location":"world-building/sects/#_4","title":"\u5929\u7384\u5b97","text":"<p>\u4ee5\u6cd5\u9635\u8457\u79f0</p> <ul> <li>\u7279\u8272\uff1a\u9635\u6cd5\u4e0e\u6cd5\u5b9d</li> <li>\u4f20\u627f\uff1a\u9635\u6cd5\u5e08\u57f9\u517b</li> <li>\u4ee3\u8868\u4eba\u7269\uff1a\u5f85\u5b9a</li> </ul>"},{"location":"world-building/sects/#_5","title":"\u4e91\u6d77\u6d3e","text":"<p>\u4e91\u4e2d\u4e4b\u5b97</p> <ul> <li>\u7279\u8272\uff1a\u5fa1\u7a7a\u98de\u884c</li> <li>\u4f20\u627f\uff1a\u98ce\u5c5e\u6027\u529f\u6cd5</li> <li>\u4f4d\u7f6e\uff1a\u4e2d\u5dde\u00b7\u4e91\u6d77\u4ed9\u5883</li> </ul>"},{"location":"world-building/sects/#_6","title":"\ud83d\udd34 \u9b54\u9053\u5b97\u95e8","text":""},{"location":"world-building/sects/#_7","title":"\u8840\u9b54\u5b97","text":"<p>\u4ee5\u8840\u9053\u8457\u79f0</p> <ul> <li>\u7279\u8272\uff1a\u8840\u796d\u3001\u878d\u5408</li> <li>\u4f20\u627f\uff1a\u8840\u9b54\u79d8\u6cd5</li> <li>\u540d\u58f0\uff1a\u81ed\u540d\u662d\u8457</li> </ul>"},{"location":"world-building/sects/#_8","title":"\u541e\u5929\u6559","text":"<p>\u63a0\u593a\u4e00\u5207</p> <ul> <li>\u7279\u8272\uff1a\u541e\u566c\u4e4b\u9053</li> <li>\u4f20\u627f\uff1a\u541e\u5929\u79d8\u6cd5</li> <li>\u884c\u4e8b\uff1a\u90aa\u6076\u6b8b\u66b4</li> </ul>"},{"location":"world-building/sects/#_9","title":"\u26aa \u4e2d\u7acb\u52bf\u529b","text":""},{"location":"world-building/sects/#_10","title":"\u5546\u4f1a\u8054\u76df","text":"<p>\u4ee5\u5546\u4e1a\u4e3a\u4e3b</p> <ul> <li>\u7279\u8272\uff1a\u4ea4\u6613\u4e0e\u4fe1\u606f</li> <li>\u4f20\u627f\uff1a\u7ecf\u8425\u4e4b\u9053</li> <li>\u5f71\u54cd\u529b\uff1a\u904d\u5e03\u5404\u5dde</li> </ul>"},{"location":"world-building/sects/#_11","title":"\u72e9\u730e\u8005\u534f\u4f1a","text":"<p>\u5192\u9669\u8005\u7684\u7ec4\u7ec7</p> <ul> <li>\u7279\u8272\uff1a\u4efb\u52a1\u7cfb\u7edf</li> <li>\u4f20\u627f\uff1a\u7ecf\u9a8c\u5206\u4eab</li> <li>\u6210\u5458\uff1a\u6765\u81ea\u5404\u5730</li> </ul>"}]}