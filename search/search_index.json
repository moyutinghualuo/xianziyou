fd7\u3002</p>"},{"location":"glossary/terms/#_15","title":"\u4ed9\u5668","text":"<p>\u4ed9\u4eba\u4f7f\u7528\u7684\u6cd5\u5b9d\uff0c\u54c1\u8d28\u8fdc\u8d85\u666e\u901a\u7075\u5b9d\u3002</p>"},{"location":"glossary/terms/#_16","title":"\u9635\u6cd5\u76f8\u5173\u672f\u8bed","text":""},{"location":"glossary/terms/#_17","title":"\u9635\u6cd5","text":"<p>\u6309\u7167\u7279\u5b9a\u65b9\u5f0f\u5e03\u7f6e\uff0c\u80fd\u4ea7\u751f\u7279\u6b8a\u6548\u679c\u7684\u6cd5\u9635\u3002</p>"},{"location":"glossary/terms/#_18","title":"\u7981\u5236","text":"<p>\u9488\u5bf9\u7279\u5b9a\u76ee\u6807\u7684\u5c0f\u578b\u9635\u6cd5\uff0c\u5e38\u7528\u4e8e\u9632\u5fa1\u3002</p>"},{"location":"glossary/terms/#_19","title":"\u62a4\u5c71\u5927\u9635","text":"<p>\u5b97\u95e8\u7ea7\u522b\u7684\u8d85\u5927\u578b\u9635\u6cd5\uff0c\u53ef\u4ee5\u4fdd\u62a4\u6574\u4e2a\u5b97\u95e8\u3002</p>"},{"location":"glossary/terms/#_20","title":"\u5176\u4ed6\u91cd\u8981\u672f\u8bed","text":""},{"location":"glossary/terms/#_21","title":"\u5316\u8eab","text":"<p>\u4fee\u4e3a\u9ad8\u6df1\u7684\u4fee\u4ed9\u8005\u5206\u51fa\u4e00\u90e8\u5206\u795e\u8bc6\u548c\u6cd5\u529b\u5f62\u6210\u7684\u5206\u8eab\u3002</p>"},{"location":"glossary/terms/#_22","title":"\u98de\u5347","text":"<p>\u4fee\u4ed9\u8005\u4fee\u4e3a\u8fbe\u5230\u4ed9\u4eba\u5706\u6ee1\u540e\uff0c\u53ef\u4ee5\u98de\u5347\u5230\u66f4\u9ad8\u7684\u4e16\u754c\u3002</p>"},{"location":"glossary/terms/#_23","title":"\u5927\u52ab","text":"<p>\u5929\u5730\u5927\u8303\u56f4\u7684\u707e\u96be\uff0c\u4f1a\u5bfc\u81f4\u5927\u91cf\u4fee\u4ed9\u8005\u9668\u843d\u3002</p>"},{"location":"glossary/terms/#_24","title":"\u79d8\u5883","text":"<p>\u9690\u85cf\u5728\u7279\u6b8a\u7a7a\u95f4\u4e2d\u7684\u5730\u70b9\uff0c\u5e38\u6709\u673a\u7f18\u548c\u5371\u9669\u3002</p>"},{"location":"plot/overview/","title":"\u6545\u4e8b\u6982\u89c8","text":""},{"location":"plot/overview/#_2","title":"\ud83d\udcda \u6587\u7ae0\u7ed3\u6784","text":""},{"location":"plot/overview/#_3","title":"\u7